# Copy to .env — never commit .env
ADX_CLUSTER_URI=https://adx-training-tcs.centralindia.kusto.windows.net
ADX_DATABASE=LogsDB_u01

# Azure subscription (adx-tools azure-subscriptions → paste ID here)
AZURE_SUBSCRIPTION_ID=

# Bronze batch ingest — storage account name without .blob.core.windows.net
ADX_STORAGE_ACCOUNT=
# true = .ingest uses ;managed_identity=system (student path). false = SAS via az storage (needs RBAC)
ADX_INGEST_USE_MANAGED_IDENTITY=true

# Day 3 streaming: set false for live Event Hub + IoT dry-run
ADX_USE_STREAMING_FALLBACK=true
ADX_EVENTHUB_NAMESPACE=eh-adx-tcs
ADX_EVENTHUB_NAME=sec-events
ADX_IOT_HUB=iot-adx-tcs
ADX_RESOURCE_GROUP=rg-adx-training-tcs
# Seconds to wait after sending streaming messages before checkpoint
ADX_STREAM_WAIT_SECONDS=30

# Seconds to wait after creating Gold MV (Day 4)
ADX_MV_WAIT_SECONDS=45

# Optional: service principal instead of az login
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# AWS — Day 7 live CloudTrail (never commit real keys)
# Prefer these over ~/.aws/credentials when set
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=          # optional — required for temporary/STS credentials
AWS_DEFAULT_REGION=ap-south-1
# Optional S3 org-trail path (auto used when set; else LookupEvents API)
# AWS_CLOUDTRAIL_S3_BUCKET=
# AWS_CLOUDTRAIL_S3_PREFIX=AWSLogs/
# AWS_CLOUDTRAIL_LOOKUP_MAX=80
#
# Live AWS → ADX (maintainer, no ADLS required):
#   az login
#   adx-tools aws live-demo --report
#   adx-tools aws live-demo --sample --report   # locked lab counts
#
# Step-by-step:
#   adx-tools aws verify
#   adx-tools aws pull-cloudtrail --source lookup --max-records 80
#   adx-tools aws ingest-inline --report
#
# Full path (needs Storage Blob Data Contributor on ADX_STORAGE_ACCOUNT):
#   adx-tools aws live-demo --try-upload --report
#   adx-tools aws sync-to-adls --source lookup --ingest --report
